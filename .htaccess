# acurioustale.de — Apache config for the static site.
# Shipped to the web root by deploy.sh. The host is Apache (shared with
# comparebuilds.app); this adds the production security headers the static
# files can't set themselves.

# ─── HTTPS Redirect ────────────────────────────────────────────────────────────
<IfModule mod_rewrite.c>
  RewriteEngine On
  # Redirect to HTTPS only when the request truly arrived over plain HTTP.
  # On a host that terminates TLS at a front proxy and forwards HTTP to Apache,
  # %{HTTPS} reads "off" even for HTTPS clients; without the X-Forwarded-Proto
  # guard that would 301 an already-secure request back to itself in an endless
  # loop. A proxy that sets X-Forwarded-Proto: https therefore suppresses the
  # redirect — but that header is client-supplied, so a request arriving straight
  # over plain HTTP could forge it and be served in cleartext. Only honour it from
  # a co-located terminator: the third condition demands a private/loopback
  # REMOTE_ADDR, so a public-internet client's forged header can't skip the
  # redirect. That allowlist spans every form such a terminator can present:
  # IPv4 loopback/private, IPv6 loopback (::1), IPv6 unique-local (fc00::/7) and
  # link-local (fe80::/10), plus the IPv4-mapped-IPv6 forms (::ffff:127…, etc.) a
  # dual-stack socket reports — so an IPv6 proxy can't fail the check and 301 an
  # already-HTTPS request into an endless loop. The redirect fires when HTTPS is
  # off AND (the proto isn't https OR the source isn't a trusted proxy) — the
  # [OR] binds only the two X-Forwarded conditions, still ANDed with %{HTTPS} off.
  RewriteCond %{HTTPS} off
  RewriteCond %{HTTP:X-Forwarded-Proto} !https [OR]
  RewriteCond %{REMOTE_ADDR} !^(127\.|10\.|172\.(1[6-9]|2[0-9]|3[01])\.|192\.168\.|::1$|::ffff:(127\.|10\.|172\.(1[6-9]|2[0-9]|3[01])\.|192\.168\.)|[fF][cCdD]|[fF][eE][89aAbB])
  # Redirect to the canonical host literally rather than reflecting %{HTTP_HOST}:
  # the Host header is client-supplied, so echoing it into the Location makes the
  # plain-HTTP hop an open redirect (a forged Host would 301 the victim to an
  # attacker origin). This file ships only to the acurioustale.de docroot, and
  # every canonical URL on the site uses that host, so pinning it also folds any
  # alias onto the canonical name.
  RewriteRule ^(.*)$ https://acurioustale.de%{REQUEST_URI} [L,R=301]
</IfModule>

# ─── Security headers ──────────────────────────────────────────────────────────
<IfModule mod_headers.c>
  # Content-Security-Policy. Everything is same-origin: the stylesheet and the
  # js/ modules are served from this host (script-src/style-src 'self'), and the
  # one inline script (the pre-paint theme guard in index.html) is allowlisted by
  # its sha256 hash. This is the production-grade superset of the <meta> CSP in
  # index.html — it adds frame-ancestors and upgrade-insecure-requests, which a
  # meta CSP can't express. The meta stays as the locally-testable baseline (the
  # python dev server doesn't apply .htaccess), and tools/check-csp.mjs asserts
  # the inline-script hash matches in BOTH places, so they can't drift.
  # IMPORTANT: the hash is over the inline script's exact bytes — edit that script
  # and you must recompute it here and in index.html (check-csp.mjs prints it).
  Header always set Content-Security-Policy "default-src 'none'; script-src 'self' 'sha256-0XS6fJmnW2SNoCoGcMrWZGB5K3ez/ROTYOgIPlaczfY='; style-src 'self'; img-src 'self'; manifest-src 'self'; base-uri 'none'; form-action 'none'; frame-ancestors 'none'; upgrade-insecure-requests"

  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "DENY"
  Header always set Referrer-Policy "no-referrer"
  Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"
  Header always set Cross-Origin-Opener-Policy "same-origin"
  Header always set Cross-Origin-Embedder-Policy "require-corp"
  Header always set Cross-Origin-Resource-Policy "same-origin"
  Header always unset Server

  # Long-cache the static images: the favicon, apple-touch icon and OG card are
  # stable (changed only by an explicit redeploy). Markup, CSS and JS use no-cache
  # so browsers always revalidate with the server, ensuring a deploy is picked up
  # immediately without filename hashing while avoiding stale heuristic caching.
  <FilesMatch "\.(png|svg)$">
    Header set Cache-Control "public, max-age=2592000"
  </FilesMatch>
  <FilesMatch "\.(html|css|js|webmanifest)$">
    Header set Cache-Control "no-cache"
  </FilesMatch>
</IfModule>

# ─── MIME types ────────────────────────────────────────────────────────────────
# Make sure the SVG favicon is served as image/svg+xml even on a host that
# doesn't map it by default.
<IfModule mod_mime.c>
  AddType image/svg+xml .svg
  # Serve the PWA manifest with its registered type on hosts that don't map it.
  AddType application/manifest+json .webmanifest
</IfModule>

# ─── Compression ───────────────────────────────────────────────────────────────
<IfModule mod_brotli.c>
  AddOutputFilterByType BROTLI_COMPRESS text/html text/plain text/xml text/css text/javascript application/javascript application/json application/manifest+json image/svg+xml
</IfModule>
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json application/manifest+json image/svg+xml
</IfModule>

# ─── Deny sensitive files (defense in depth) ───────────────────────────────────
# Block dotfiles (this .htaccess, any stray .env) from being served. This is a
# static site with no PHP, so config.php and *.example never exist here — they're
# denied anyway to match the shared-host sibling (comparebuilds.app) and guard
# against a stray copy or template ever landing in the web root.
<FilesMatch "(^\.|\.example$|^config\.php$)">
  Require all denied
</FilesMatch>
